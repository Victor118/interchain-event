# Multi-stage dev image: Rust toolchain + gaiad + neutrond CLI
# Build: docker build -f Dockerfile.dev -t interchain-dev .
# Or:    docker compose build

ARG GAIA_VERSION=v27.1.0
ARG NEUTRON_VERSION=v10.1.0
ARG RUST_VERSION=1.86

# --- Stage 1: grab gaiad binary from official image ---
FROM ghcr.io/cosmos/gaia:${GAIA_VERSION} AS gaia

# --- Stage 2: grab neutrond binary from official image ---
FROM neutronorg/neutron:${NEUTRON_VERSION} AS neutron

# --- Stage 3: Rust dev environment ---
FROM rust:${RUST_VERSION}-bookworm

# gaiad CLI
COPY --from=gaia /usr/local/bin/gaiad /usr/local/bin/gaiad

# neutrond CLI
COPY --from=neutron /usr/bin/neutrond /usr/local/bin/neutrond

# wasm32 target
RUN rustup target add wasm32-unknown-unknown

# wasm-opt (recent version for Rust 1.86+ wasm output)
ARG BINARYEN_VERSION=version_123
RUN curl -sSL "https://github.com/WebAssembly/binaryen/releases/download/${BINARYEN_VERSION}/binaryen-${BINARYEN_VERSION}-x86_64-linux.tar.gz" \
    | tar -xz -C /usr/local --strip-components=1

WORKDIR /code

# Default shell entrypoint
CMD ["bash"]
